# LLM API Keys
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key
ANTHROPIC_API_KEY=your_anthropic_key
GROQ_API_KEY=your_groq_key

# --- Agent Orchestration & Training ---
# Set to 'true' to use local Gemma/Llama via Ollama for decisions
USE_LLM_TRADER=false
TRADER_MODEL=qwen2.5:1.5b
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_KEY=ollama
USE_LOCAL_POLICY=false
LOCAL_MODEL_PATH=models/local_policy
ENABLE_REMOTE_PM=false
ENABLE_REMOTE_JUDGE=false

# The Remote Judge (Llama 3.3 70B via OpenAI-compatible client)
JUDGE_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- Financial Data Keys (Optional) ---
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
